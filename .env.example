# ==============================
# APP / ENVIRONMENT
# ==============================
# Ten ung dung backend (dung de hien thi log va metadata).
APP_NAME = RAG App Backend
# Moi truong chay: development | staging | production.
APP_ENV = development


# ==============================
# SECURITY / AUTH
# ==============================
# Secret dung de ky JWT token. Bat buoc doi sang gia tri manh khi len production.
SECRET_KEY = change-this-secret-key-in-production
# Thoi gian het han access token (phut).
ACCESS_TOKEN_EXPIRE_MINUTES = 1440
# Tai khoan admin mac dinh duoc tao luc khoi tao he thong.
ADMIN_DEFAULT_USERNAME = admin
# Mat khau admin mac dinh. Nen doi ngay sau khi deploy.
ADMIN_DEFAULT_PASSWORD = Admin@123


# ==============================
# OLLAMA CONNECTION (CLIENT)
# ==============================
# URL backend Ollama API de goi chat/metadata/hyq.
OLLAMA_BASE_URL = http://localhost:11434
# So thread Ollama su dung cho moi request (tham so runtime per request).
OLLAMA_NUM_THREAD = 8


# ==============================
# EMBEDDING SETTINGS
# ==============================
# Ten model embedding su dung de vector hoa van ban.
EMBEDDING_MODEL_NAME = BAAI/bge-m3
# Gioi han token/chieu dai toi da moi doan truoc khi embedding.
EMBEDDING_MAX_LENGTH = 512
# Bat FP16 de tang toc tren GPU (co the giam nhe do chinh xac).
EMBEDDING_USE_FP16 = true
# Kich thuoc batch cho embedding.
EMBEDDING_BATCH_SIZE = 64
# Thiet bi chay embedding: auto | cpu | cuda.
EMBEDDING_DEVICE = auto
# Chi dung model local, khong tai tu internet (true/false).
EMBEDDING_LOCAL_FILES_ONLY = false


# ==============================
# VECTOR DATABASE (QDRANT)
# ==============================
# Qdrant URL (bo trong neu dung local embedded mode cua ung dung).
QDRANT_URL = 
# API key cho Qdrant cloud/remote.
QDRANT_API_KEY = 
# Ten collection luu vector chunk con.
QDRANT_COLLECTION_NAME = global_child_chunks
# So luong vector upsert moi batch khi indexing.
VECTOR_BATCH_SIZE = 64


# ==============================
# DOCUMENT PARSING / CHUNKING
# ==============================
# Parser PDF: marker | header_split (phu thuoc implementation hien co).
PDF_PARSER_MODE = marker
# Do dai ky tu cho moi chunk truoc khi dua vao index.
CHUNK_SIZE = 1000
# So ky tu overlap giua hai chunk lien tiep.
CHUNK_OVERLAP = 150


# ==============================
# CHAT LLM (ANSWER GENERATION)
# ==============================
# Model chat chinh de tao cau tra loi.
LLM_MODEL = llama3.1:8b
# Nhiet do sinh text (0 = on dinh, cao hon = da dang hon).
LLM_TEMPERATURE = 0
# So token context toi da cho model chat.
LLM_NUM_CTX = 2048
# Thoi gian giu model chat trong bo nho o phia runtime request (vd: 10m, -1).
LLM_KEEP_ALIVE = 10m


# ==============================
# RETRIEVAL CORE
# ==============================
# So chunk lay ra ban dau truoc cac buoc nang cao (rewrite/multi-query/rerank).
RETRIEVER_K = 4


# ==============================
# QUERY REWRITE
# ==============================
# Bat/tat viet lai truy van de toi uu tim kiem.
QUERY_REWRITE_ENABLED = false
# So term toi thieu khi tao truy van rewrite.
QUERY_REWRITE_MIN_TERMS = 4
# So term toi da khi tao truy van rewrite.
QUERY_REWRITE_MAX_TERMS = 8


# ==============================
# MULTI-QUERY RETRIEVAL
# ==============================
# Bat/tat tao nhieu bien the cau hoi de truy xuat rong hon.
MULTI_QUERY_ENABLED = true
# So bien the truy van duoc tao.
MULTI_QUERY_VARIANTS = 3
# So worker song song cho multi-query.
MULTI_QUERY_MAX_WORKERS = 3
# Model dung de tao cac bien the truy van.
MULTI_QUERY_MODEL = "llama3.2:3b"


# ==============================
# HYBRID RETRIEVAL (VECTOR + KEYWORD)
# ==============================
# Trong so RRF cho kenh vector.
HYBRID_VECTOR_RRF_WEIGHT = 1.0
# Trong so RRF cho kenh keyword/BM25.
HYBRID_KEYWORD_RRF_WEIGHT = 1.2
# He so k trong Reciprocal Rank Fusion.
HYBRID_RRF_K = 60
# He so mo rong candidate truoc khi fusion.
HYBRID_PROBE_MULTIPLIER = 4


# ==============================
# RERANKER
# ==============================
# Bat/tat rerank sau khi lay candidate.
RERANKER_ENABLED = true
# Model reranker dung de cham lai do lien quan.
RERANKER_MODEL = "BAAI/bge-reranker-v2-m3"
# So ket qua cuoi cung sau rerank.
RERANKER_TOP_K = 4
# So candidate dua vao reranker.
RERANKER_CANDIDATE_POOL = 20


# ==============================
# HYQ (HYPOTHETICAL QUESTIONS)
# ==============================
# Bat/tat sinh cau hoi gia dinh phuc vu retrieval/index.
HYQ_ENABLED = true
# Dung LLM de tao HYQ hay dung rule-based.
HYQ_USE_LLM = true
# Model dung cho tao HYQ.
HYQ_MODEL = llama3.2:3b
# Do dai tom tat HYQ (so tu muc tieu).
HYQ_SUMMARY_WORDS = 50
# So cau hoi HYQ sinh tren moi chunk.
HYQ_QUESTIONS_PER_CHUNK = 3


# ==============================
# METADATA EXTRACTION
# ==============================
# Bat/tat su dung LLM de trich metadata.
METADATA_USE_LLM = true
# Model chinh cho metadata extraction.
METADATA_MODEL = llama3.2:3b
# Bat che do tom tat chat luong cao (thuong cham hon).
METADATA_SUMMARY_USE_HIGH_ACCURACY = false
# Model tom tat metadata.
METADATA_SUMMARY_MODEL = llama3.1:8b
# Context token cho model tom tat metadata.
METADATA_SUMMARY_NUM_CTX = 2048
# So worker xu ly metadata song song.
METADATA_MAX_WORKERS = 4
# So thread Ollama cho metadata request.
METADATA_OLLAMA_NUM_THREAD = 8
# So token sinh toi da cho metadata request.
METADATA_OLLAMA_NUM_PREDICT = 192
# Context token cho metadata model.
METADATA_NUM_CTX = 1536
# Keep alive cho model metadata o request runtime (-1 = giu lau).
METADATA_KEEP_ALIVE = -1
# Batch size khi gui metadata prompts len LLM.
METADATA_LLM_BATCH_SIZE = 8
# Gioi han tong ky tu moi batch metadata LLM.
METADATA_LLM_BATCH_MAX_CHARS = 12000


# ==============================
# OLLAMA DAEMON RUNTIME (SERVER-SIDE)
# Dat cac bien nay truoc khi chay `ollama serve`
# ==============================
# So request dong thoi toi da Ollama daemon xu ly.
OLLAMA_NUM_PARALLEL = 2
# So model toi da duoc nap cung luc trong daemon.
OLLAMA_MAX_LOADED_MODELS = 3
# Keep alive mac dinh cua daemon cho model da nap (-1 = giu den khi bi day ra).
OLLAMA_KEEP_ALIVE = -1
# Kieu KV cache (anh huong memory/toc do).
OLLAMA_KV_CACHE_TYPE = q8_0
# Bat Flash Attention neu phan cung/driver ho tro.
OLLAMA_FLASH_ATTENTION = 1


# ==============================
# MODEL WARMUP (BACKEND STARTUP)
# ==============================
# Bat warmup tong khi backend startup.
MODEL_WARMUP_ON_STARTUP = false
# Warmup model metadata khi startup.
MODEL_WARMUP_METADATA = true
# Warmup model embedding khi startup.
MODEL_WARMUP_EMBEDDING = true
# Warmup model chat khi startup.
MODEL_WARMUP_CHAT = false


# ==============================
# FRONTEND
# ==============================
# Base URL frontend dung de goi backend API.
VITE_API_BASE_URL = "http://localhost:8000/api"