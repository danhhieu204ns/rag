APP_NAME = RAG App Backend
APP_ENV = development
OLLAMA_BASE_URL = http://localhost:11434
EMBEDDING_BACKEND = sentence-transformers
EMBEDDING_MODEL_NAME = BAAI/bge-m3
EMBEDDING_MAX_LENGTH = 512
EMBEDDING_USE_FP16 = true
EMBEDDING_BATCH_SIZE = 64
EMBEDDING_DEVICE = auto
EMBEDDING_LOCAL_FILES_ONLY = false
QDRANT_URL = 
QDRANT_API_KEY = 
QDRANT_COLLECTION_NAME = global_child_chunks
PDF_PARSER_MODE = legacy
CHUNK_SIZE = 500
CHUNK_OVERLAP = 50
RETRIEVER_K = 4
LLM_MODEL = llama3.1:8b
LLM_TEMPERATURE = 0
LLM_NUM_CTX = 2048
LLM_KEEP_ALIVE = 10m
OLLAMA_NUM_THREAD = 8
SECRET_KEY = change-this-secret-key-in-production
ACCESS_TOKEN_EXPIRE_MINUTES = 1440
ADMIN_DEFAULT_USERNAME = admin
ADMIN_DEFAULT_PASSWORD = Admin@123
HYQ_ENABLED = true
HYQ_USE_LLM = true
HYQ_MODEL = llama3.2:3b
METADATA_USE_LLM = true
METADATA_MODEL = llama3.2:3b
METADATA_SUMMARY_USE_HIGH_ACCURACY = false
METADATA_SUMMARY_MODEL = llama3.1:8b
METADATA_SUMMARY_NUM_CTX = 2048
METADATA_MAX_WORKERS = 4
METADATA_OLLAMA_NUM_THREAD = 8
METADATA_OLLAMA_NUM_PREDICT = 192
METADATA_NUM_CTX = 1536
METADATA_KEEP_ALIVE = -1
METADATA_LLM_BATCH_SIZE = 8
METADATA_LLM_BATCH_MAX_CHARS = 12000
EMBEDDING_KEEP_ALIVE = -1
HYQ_SUMMARY_WORDS = 50
HYQ_QUESTIONS_PER_CHUNK = 3
VECTOR_BATCH_SIZE = 64
HYBRID_VECTOR_RRF_WEIGHT = 1.0
HYBRID_KEYWORD_RRF_WEIGHT = 1.2
HYBRID_RRF_K = 60
HYBRID_PROBE_MULTIPLIER = 4

# Ollama daemon runtime knobs (set before starting `ollama serve`):
OLLAMA_NUM_PARALLEL = 2
OLLAMA_MAX_LOADED_MODELS = 3
OLLAMA_KEEP_ALIVE = -1
OLLAMA_KV_CACHE_TYPE = q8_0
OLLAMA_FLASH_ATTENTION = 1

# Warmup selected models at backend startup (optional)
MODEL_WARMUP_ON_STARTUP = false
MODEL_WARMUP_METADATA = true
MODEL_WARMUP_EMBEDDING = true
MODEL_WARMUP_CHAT = false

VITE_API_BASE_URL = "http://localhost:8000/api"